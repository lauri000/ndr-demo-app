# Shared build metadata. Leave git SHA and timestamp empty to derive them from HEAD.
NDR_APP_VERSION_NAME=0.1.0
NDR_APP_VERSION_CODE=1
NDR_BUILD_GIT_SHA=
NDR_BUILD_TIMESTAMP_UTC=

# Shared Rust relay defaults compiled into mobile release builds.
NDR_RELEASE_RELAY_SET_ID=public-release
NDR_RELEASE_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net

# Optional beta relay overrides.
NDR_BETA_RELAY_SET_ID=beta-fallback
NDR_BETA_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.primal.net

# Android signing for Play/Test releases.
NDR_RELEASE_KEYSTORE_PATH=
NDR_RELEASE_KEYSTORE_PASSWORD=
NDR_RELEASE_KEY_ALIAS=
NDR_RELEASE_KEY_PASSWORD=

# Optional dedicated beta signing. If omitted, beta falls back to release signing, then debug signing.
NDR_BETA_KEYSTORE_PATH=
NDR_BETA_KEYSTORE_PASSWORD=
NDR_BETA_KEY_ALIAS=
NDR_BETA_KEY_PASSWORD=

# iOS TestFlight / App Store distribution.
NDR_IOS_BUNDLE_ID=social.innode.irischat
NDR_IOS_DEVELOPMENT_TEAM=
NDR_IOS_SIGNING_STYLE=automatic
NDR_IOS_EXPORT_METHOD=app-store-connect
NDR_IOS_INTERNAL_ONLY=false
NDR_IOS_ALLOW_PROVISIONING_UPDATES=false

# Optional App Store Connect authentication key for scripted archive/export/upload.
NDR_ASC_AUTH_KEY_PATH=
NDR_ASC_AUTH_KEY_ID=
NDR_ASC_AUTH_KEY_ISSUER_ID=
